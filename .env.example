# soc-validate — purple-team detection validation
VAL_HOST=0.0.0.0
VAL_PORT=8104
# Atomic Red Team atomics (bundled submodule).
ATOMICS_DIR=./atomics/atomics
# soc-ops API used to confirm a detection fired after a run.
SOC_OPS_URL=http://localhost:8081
# SAFETY: 0 = dry-run only (default). 1 = actually execute sh/bash atomics on THIS host.
# Only enable on a scoped lab endpoint. Each execute also needs confirm=1 per run.
EXECUTION_ENABLED=0
# Seconds to scan soc-ops for a matching alert after a run.
DETECT_WINDOW=45
RUN_TIMEOUT=60
